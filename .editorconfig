root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_style_namespace_declarations = file_scoped:warning

# Anki's public format vocabulary intentionally uses Collection, Queue, and GUID.
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1720.severity = none

[src/AnkiIO/Packages/AnkiPackageReader.cs]
# The path and stream entry points intentionally share optional limits and cancellation arguments.
dotnet_diagnostic.RS0026.severity = none

[src/AnkiIO/Packages/AnkiPackageWriter.cs]
# The deck/package and path/stream entry points intentionally share an optional cancellation argument.
dotnet_diagnostic.RS0026.severity = none
